{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smart-vms.local/schemas/detection-payload/1.0",
  "title": "DetectionPayload",
  "type": "object",
  "required": ["frame_ts", "objects"],
  "properties": {
    "frame_ts": { "type": "string", "format": "date-time" },
    "model": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "objects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["class", "confidence", "bbox_norm"],
        "properties": {
          "class": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "bbox_norm": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 4,
            "maxItems": 4
          },
          "track_id": { "type": "string" }
        }
      }
    },
    "zone_ids": { "type": "array", "items": { "type": "string" } }
  }
}
