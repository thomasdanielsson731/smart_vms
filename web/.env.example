# Kopiera till .env och justera vid behov

# --- Inloggning (obligatoriskt för att använda appen) ---
# Generera hemlig nyckel: openssl rand -hex 32
SMARTVMS_SESSION_SECRET=
SMARTVMS_ADMIN_USER=admin
SMARTVMS_ADMIN_PASSWORD=
# Valfritt: läsbehörighet (video/larm, ej onboarding eller larmregler)
SMARTVMS_VIEWER_USER=
SMARTVMS_VIEWER_PASSWORD=
SMARTVMS_SESSION_TTL_HOURS=8
# Sätt true bakom HTTPS (produktion / reverse proxy)
SMARTVMS_COOKIE_SECURE=false

# Ollama (lokal Qwen) — Copilot-chatt
VITE_OLLAMA_BASE_URL=/api/ollama
VITE_OLLAMA_MODEL=qwen2.5-coder:7b

# Axis live video (VAPIX) — required for camera streams
# Usually root + the password you use in the camera web UI
# Prefer a dedicated VAPIX service account (not personal admin) in production
AXIS_VAPIX_USER=root
AXIS_VAPIX_PASSWORD=

# Real camera IPs (comma-separated) — used as subnet hint and fallback seeds
# Onboarding scans the whole /24; restart dev server after change
VITE_CAMERA_HOSTS=192.168.68.200
# Optional: override scan range (private /24 only), e.g. 192.168.68.0/24
# VITE_CAMERA_SUBNET=192.168.68.0/24

# Dev-only: allow 127.0.0.1 as camera host (default blocked for SSRF safety)
# SMARTVMS_ALLOW_LOCALHOST_CAMERA=true

# Set to false to disable live video in the UI
VITE_CAMERA_STREAM_ENABLED=true

# Face identification workspace (opt-in — off by default for privacy)
# VITE_FACE_RECOGNITION_ENABLED=true

# Add cameras via Onboarding or set VITE_CAMERA_HOSTS above and restart the dev server.
